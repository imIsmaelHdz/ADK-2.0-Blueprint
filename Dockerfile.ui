FROM node:22-slim AS builder

WORKDIR /app
COPY chatbot-ui/package*.json ./
RUN npm ci
COPY chatbot-ui/ ./
RUN npm run build

FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/templates/default.conf.template

EXPOSE 8080

# envsubst replaces ${API_URL} in the template at container start
CMD ["/bin/sh", "-c", "envsubst '${API_URL}' < /etc/nginx/templates/default.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
