# Copy to `.env` and fill values. `.env` is gitignored.

# Google AI Studio — use for local `adk web` / `adk run`
# Create a key: https://aistudio.google.com/apikey — paste it on the line below (no quotes).
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# Google Cloud Vertex AI — uncomment when you have a real project/region and ADC
# (see setup.md: gcloud auth application-default login, enable aiplatform.googleapis.com)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Travel helper — assistant response guard (Guardrails). Off unless set to 1/true/yes/on.
# TRAVEL_HELPER_GUARDRAILS_ENABLED=1
# TRAVEL_HELPER_GUARDRAILS_BANNED_TERMS=phrase1,phrase2

# Travel helper — RAG via Vertex AI Vector Search 2.0 (requires ADC and Vertex project/region).
# TRAVEL_HELPER_USE_RAG=1
# TRAVEL_HELPER_RAG_COLLECTION_ID=travel-helper-docs
# TRAVEL_HELPER_RAG_GCS_URI=gs://your-bucket/path-prefix
# TRAVEL_HELPER_RAG_EMBEDDING_FIELD=content_embedding
# Ingest caps (avoid runaway list/download cost if prefix is wrong or bucket is huge)
# TRAVEL_HELPER_RAG_INGEST_MAX_FILES=500
# TRAVEL_HELPER_RAG_INGEST_MAX_LIST_ITEMS=10000
# TRAVEL_HELPER_RAG_INGEST_MAX_BYTES_PER_DOC=5242880
# TRAVEL_HELPER_RAG_INGEST_MAX_TOTAL_BYTES=52428800
# RPC / download deadlines (seconds) for Vector Search and GCS reads
# TRAVEL_HELPER_RAG_SEARCH_TIMEOUT_SEC=90
# TRAVEL_HELPER_RAG_BATCH_CREATE_TIMEOUT_SEC=180
# TRAVEL_HELPER_RAG_GCS_DOWNLOAD_TIMEOUT_SEC=120
